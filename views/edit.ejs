<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>게시물 수정</title>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container" style="max-width: 800px; margin-top: 80px;">
    <h3 class="mb-4">게시물 수정</h3>
    <form method="POST" action="/edit/<%= post._id %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="mb-3">
        <label class="form-label" for="title">제목</label>
        <input class="form-control" id="title" name="title" value="<%= post.제목 %>" required>
      </div>
      <div class="mb-3">
        <label class="form-label" for="content">내용</label>
        <textarea class="form-control" id="content" name="content" rows="10" required><%= post.내용 %></textarea>
      </div>
      <div class="d-flex justify-content-between">
        <a class="btn btn-outline-secondary" href="/detail/<%= post._id %>">취소</a>
        <button class="btn btn-primary" type="submit">저장</button>
      </div>
    </form>
  </div>
</body>
</html>


## App
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me

## MongoDB
# Docker Compose (service name: mongodb)
DB_URL=mongodb://admin:password@mongodb:27017/server?authSource=admin

# Local run (if MongoDB is exposed on host)
# DB_URL=mongodb://admin:password@localhost:27018/server?authSource=admin

MONGO_USERNAME=admin
MONGO_PASSWORD=password

## Email (optional - required for password reset emails)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password

